# ============================================
# DKPT — Variables d'environnement (Template)
# ============================================
# Copiez ce fichier en .env et modifiez les valeurs

# --- PostgreSQL ---
POSTGRES_DB=dkpt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# --- Backend .NET 9 ---
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=dkpt;Username=postgres;Password=CHANGE_ME
Jwt__SecretKey=CHANGE_THIS_SUPER_SECRET_KEY_MIN_32_CHARS_LONG!
Jwt__Issuer=dkpt-api
Jwt__Audience=dkpt-client
Cors__Origins=http://localhost;http://localhost:80

# --- Frontend Nuxt 4 ---
NUXT_PUBLIC_API_BASE=/api
NUXT_API_BASE_INTERNAL=http://backend:8080/api
